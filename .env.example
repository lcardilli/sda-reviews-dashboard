# Apify API token — get yours at https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# Gmail SMTP credentials for digest notifications
# Use an App Password (not your main password): https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
