{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "reviews.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/reviews.json",
      "dest": "/reviews.json"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
